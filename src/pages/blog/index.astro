---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="Pool Care Blog | Royal Blue Pool Service Midlothian TX"
  description="Pool maintenance tips, water chemistry guides, and expert advice from Royal Blue Pool Service. Serving Midlothian and Ellis County, TX."
  canonicalUrl="https://royalbluepools.org/blog"
>

  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Blog', href: '/blog' },
  ]} />

  <section class="section">
    <div class="container">
      <div class="section-label">Pool Care Tips</div>
      <h1>Pool Service Blog</h1>
      <p class="section-subtitle">Expert advice on pool maintenance, water chemistry, equipment care, and more from Midlothian's trusted pool service team.</p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      {posts.length === 0 ? (
        <p style="text-align: center;">No posts yet. Check back soon!</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="blog-card">
              {post.data.image && (
                <div class="blog-card-image">
                  <img src={post.data.image} alt={post.data.image_alt || post.data.title} width="400" height="220" loading="lazy" decoding="async" />
                </div>
              )}
              <div class="blog-card-body">
                <p class="blog-card-date">
                  {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                <h2 class="blog-card-title">{post.data.title}</h2>
                <p class="blog-card-excerpt">{post.data.excerpt}</p>
                <span class="blog-card-link">Read More &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready for a Crystal-Clear Pool?</h2>
      <p>Get a free estimate from Midlothian's trusted pool service. Over 20 years of experience, licensed, insured, and ready to help.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary">Get Your Free Estimate</a>
        <a href="tel:2142437107" class="btn btn-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (214) 243-7107
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
