---
import BaseLayout from '../layouts/BaseLayout.astro';

const phone = '(214) 243-7107';
const phoneClean = phone.replace(/[^+\d]/g, '');

const services = [
  {
    name: 'Weekly Pool Maintenance',
    description: 'Consistent weekly cleaning, chemical balancing, and equipment checks to keep your pool sparkling all season long.',
    href: '/services/weekly-pool-maintenance',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>'
  },
  {
    name: 'Pool Equipment Repair',
    description: 'Certified Pentair and Polaris warranty service for pumps, filters, heaters, cleaners, and all pool equipment.',
    href: '/services/pool-equipment-repair',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>'
  },
  {
    name: 'Green Pool Recovery',
    description: 'Algae-infested pool? We restore green pools to crystal-clear condition with professional shock treatment and filtration.',
    href: '/services/green-pool-recovery',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 14.69c1.32 0 2.4-1.1 2.4-2.43 0-.7-.34-1.36-1.02-1.92-.68-.56-1.22-1.29-1.38-2.04-.16.75-.7 1.48-1.38 2.04-.68.56-1.02 1.22-1.02 1.92 0 1.33 1.08 2.43 2.4 2.43z"/><path d="M17 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S17.29 6.75 17 5.3c-.29 1.45-1.14 2.84-2.29 3.76S13 11.1 13 12.25c0 2.22 1.8 4.05 4 4.05z"/></svg>'
  },
  {
    name: 'Pool Remodeling',
    description: 'Transform your pool with Stonescapes replastering, tile upgrades, and complete pool renovations that last for decades.',
    href: '/services/pool-remodeling',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>'
  },
  {
    name: 'Filter Cleaning',
    description: 'Regular filter cleaning and replacement to maintain optimal water flow, clarity, and pool system performance.',
    href: '/services/filter-cleaning',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>'
  },
  {
    name: 'Pool Education',
    description: 'Free 30-minute on-site sessions for new pool owners. Learn equipment operation and water chemistry basics.',
    href: '/services/pool-education',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>'
  },
];

const testimonials = [
  {
    quote: "Appointment was quickly acknowledged and scheduled. Derrick showed up and was very knowledgeable about the pool and equipment. He solved the problem and the pricing was very reasonable.",
    author: "Mary J.",
    source: "Yelp",
    rating: 5,
    featured: true
  },
  {
    quote: "Excellent customer experience with high quality at very reasonable rates. Highly recommend Royal Blue Pool Service.",
    author: "Gordon D.",
    source: "Yelp",
    rating: 5,
    featured: false
  },
  {
    quote: "Derrick has been servicing my pool for the last 2 years and it always looks amazing! I can count on him like clockwork!",
    author: "Robert Lewis",
    source: "Alignable",
    rating: 5,
    featured: false
  },
  {
    quote: "Great experience with warranty assistance on our pump repair. Derrick walked us through our equipment replacement options and made sure we understood everything.",
    author: "Taylor R.",
    source: "Yelp",
    rating: 5,
    featured: false
  },
  {
    quote: "We had pool issues after purchasing our home and Royal Blue did an excellent replaster job using Stonescapes. The pool looks brand new.",
    author: "Lindsey B.",
    source: "Yelp",
    rating: 5,
    featured: false
  },
];

const galleryItems = [
  { src: '/images/gallery/replaster-tahoe-blue-before-after.jpg', alt: 'Pool replaster before and after using Stonescapes Tahoe Blue Mini Pebble finish', caption: 'Replaster: Stonescapes Tahoe Blue', type: 'before-after' },
  { src: '/images/gallery/tahoe-blue-stonescapes-after.jpg', alt: 'Finished pool with Tahoe Blue Stonescapes plaster finish', caption: 'Tahoe Blue Stonescapes Finish', type: 'after' },
  { src: '/images/gallery/retile-before-after.jpg', alt: 'Pool retile project showing before and after results', caption: 'Complete Pool Retile', type: 'before-after' },
  { src: '/images/gallery/pool-remodel-glass-tile.jpg', alt: 'Pool remodel with glass tile and wet edge plaster', caption: 'Glass Tile Remodel', type: 'after' },
  { src: '/images/gallery/acid-wash-before-after-02.jpg', alt: 'Pool acid wash before and after showing dramatic surface restoration', caption: 'Acid Wash Restoration', type: 'before-after' },
  { src: '/images/gallery/remodel-after.jpg', alt: 'Completed pool remodel with new plaster and tile', caption: 'Complete Pool Remodel', type: 'after' },
];

const serviceAreas = [
  'Midlothian', 'DeSoto', 'Cedar Hill', 'Duncanville', 'Oak Cliff',
  'Grand Prairie', 'Lancaster', 'Red Oak', 'Ovilla', 'Pecan Hill',
  'Oak Leaf', 'Waxahachie', 'Ferris', 'Ennis'
];

const faqs = [
  {
    question: "How often should I have my pool professionally serviced?",
    answer: "We recommend weekly pool maintenance for optimal water chemistry and cleanliness. Texas heat accelerates algae growth and chemical evaporation, making consistent weekly service essential. Our weekly plans include skimming, vacuuming, brushing, chemical testing and balancing, and equipment checks."
  },
  {
    question: "What areas do you serve around Midlothian?",
    answer: "Royal Blue Pool Service proudly serves Midlothian and the surrounding communities in Ellis County and southern Dallas County, including DeSoto, Cedar Hill, Duncanville, Red Oak, Ovilla, Waxahachie, Lancaster, Grand Prairie, Ferris, Ennis, Oak Cliff, Pecan Hill, and Oak Leaf."
  },
  {
    question: "Are you licensed and insured?",
    answer: "Yes. Royal Blue Pool Service is fully licensed by the Texas Department of Licensing and Regulation (TICL #1056) and fully insured. Owner Derrick Jackson brings over 20 years of professional pool service experience."
  },
  {
    question: "What pool equipment brands do you service?",
    answer: "We are a Certified Pentair Warranty Service Center and a Certified Polaris Warranty Dealer, which means we can perform warranty repairs on Pentair pumps, filters, heaters, and Polaris automatic cleaners. We also service equipment from all major manufacturers."
  },
  {
    question: "Do you offer free estimates?",
    answer: "Yes, we provide free repair and remodel estimates. We also offer a free 30-minute on-site pool education session for new pool owners in our service area, where we teach you about your equipment and basic water chemistry."
  },
  {
    question: "How do you handle a green pool?",
    answer: "Our green pool recovery service involves a multi-step process: assessing the cause of the algae bloom, performing a professional shock treatment, running filtration cycles, brushing pool surfaces, and rebalancing all chemical levels. Most green pools are restored to crystal-clear condition within 3-5 days depending on severity."
  },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Royal Blue Pool Service",
  "description": "Family-owned pool service company in Midlothian, TX offering weekly maintenance, equipment repair, green pool recovery, remodeling, and free pool education. Licensed (TICL #1056), insured, and serving Ellis County and southern Dallas County for over 20 years.",
  "url": "https://royalbluepools.org",
  "telephone": "(214) 243-7107",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "4040 Zachs Ct",
    "addressLocality": "Midlothian",
    "addressRegion": "TX",
    "postalCode": "76065",
    "addressCountry": "US"
  },
  "areaServed": serviceAreas.map(area => ({
    "@type": "City",
    "name": area + ", TX"
  })),
  "founder": { "@type": "Person", "name": "Derrick Jackson" },
  "sameAs": [
    "https://www.facebook.com/royalbluepoolsllc/",
    "https://www.yelp.com/biz/royal-blue-pool-service-midlothian",
    "https://nextdoor.com/pages/royal-blue-pool-service-duncanville-tx/"
  ],
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.7", "reviewCount": "7", "bestRating": "5" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Pool Services",
    "itemListElement": services.map(s => ({ "@type": "Offer", "itemOffered": { "@type": "Service", "name": s.name, "description": s.description } }))
  },
  "review": testimonials.slice(0, 3).map(t => ({
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": t.rating, "bestRating": 5 },
    "author": { "@type": "Person", "name": t.author },
    "reviewBody": t.quote
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const title = "Pool Service in Midlothian, TX | Royal Blue Pools";
const description = "Licensed pool service in Midlothian, TX. Weekly maintenance, equipment repair, green pool recovery & remodeling. Certified Pentair dealer. Free estimates.";
---
<BaseLayout
  title={title}
  description={description}
  canonicalUrl="https://royalbluepools.org"
  jsonLd={[localBusinessSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" style="background-image: url('/images/gallery/remodel-after.jpg'); background-color: #0F172A;"></div>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="star-rating">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        42 Five-Star Nextdoor Recommendations
      </div>
      <h1>Trusted Pool Service in Midlothian, TX</h1>
      <p class="hero-tagline">Family-owned and operated with over 20 years of experience. Licensed, insured, and certified to keep your pool crystal clear year-round.</p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Get a Free Estimate</a>
        <a href={`tel:${phoneClean}`} class="btn btn-phone">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {phone}
        </a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-number">20+</span>
          <span class="hero-stat-label">Years Experience</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-number">4.7</span>
          <span class="hero-stat-label">Google Rating</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-number">TICL #1056</span>
          <span class="hero-stat-label">Texas Licensed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <section class="trust-badges">
    <div class="container">
      <div class="trust-badges-grid">
        <div class="trust-badge">
          <div class="trust-badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
          </div>
          <div>
            <div class="trust-badge-text">20+ Years Experience</div>
            <div class="trust-badge-sub">Serving Ellis County since 2005</div>
          </div>
        </div>
        <div class="trust-badge">
          <div class="trust-badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <div class="trust-badge-text">Licensed & Insured</div>
            <div class="trust-badge-sub">TICL #1056</div>
          </div>
        </div>
        <div class="trust-badge">
          <div class="trust-badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          </div>
          <div>
            <div class="trust-badge-text">Certified Pentair & Polaris</div>
            <div class="trust-badge-sub">Authorized warranty center</div>
          </div>
        </div>
        <div class="trust-badge">
          <div class="trust-badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div>
            <div class="trust-badge-text">4.7-Star Google Rating</div>
            <div class="trust-badge-sub"><span class="star-rating">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-label">What We Do</div>
      <h2>Pool Services in Midlothian & Ellis County</h2>
      <p class="section-subtitle">From weekly maintenance to complete remodels, we handle every aspect of pool care with the expertise and certifications to back it up.</p>
      <div style="margin-top: var(--space-lg);"></div>
      <div class="services-grid">
        {services.map(service => (
          <a href={service.href} class="service-card" style="text-decoration: none; color: inherit;">
            <div class="service-card-icon" set:html={service.icon}></div>
            <h3>{service.name}</h3>
            <p>{service.description}</p>
            <span class="service-card-link">Learn More &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us — with real photo -->
  <section class="section-alt" id="why-us">
    <div class="container">
      <div class="section-label">Why Royal Blue</div>
      <h2>Why Midlothian Trusts Royal Blue</h2>
      <div style="margin-top: var(--space-lg);"></div>
      <div class="why-choose-grid">
        <div class="why-choose-image">
          <img src="/images/gallery/plaster-sapphire-treasure.jpg" alt="Wet Edge Primera Stone Sapphire Treasure pool plaster finish by Royal Blue Pool Service" width="1000" height="750" loading="lazy" decoding="async" />
          <div class="why-choose-stat">
            <div class="why-choose-stat-number">42</div>
            <div class="why-choose-stat-label">Nextdoor Recommendations</div>
          </div>
        </div>
        <div class="why-choose-features">
          <div class="why-feature">
            <div class="why-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <h3>Family-Owned & Operated</h3>
              <p>Derrick and Nicole Jackson personally oversee every pool we service. When you call Royal Blue, you talk to the owner — not a call center.</p>
            </div>
          </div>
          <div class="why-feature">
            <div class="why-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>
            <div>
              <h3>Certified Warranty Center</h3>
              <p>As a Certified Pentair Warranty Service Center and Polaris Warranty Dealer, we handle warranty repairs that most pool companies can't.</p>
            </div>
          </div>
          <div class="why-feature">
            <div class="why-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <div>
              <h3>Licensed & Fully Insured</h3>
              <p>Texas TICL #1056. Every technician is background-checked and insured, so you can trust who's working on your property.</p>
            </div>
          </div>
          <div class="why-feature">
            <div class="why-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div>
              <h3>Free Pool Education</h3>
              <p>New pool owner? We offer a free 30-minute on-site session to teach you how your equipment works and how to maintain proper water chemistry.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" id="testimonials">
    <div class="container">
      <div class="section-label">What Our Customers Say</div>
      <h2>Trusted by Pool Owners Across Ellis County</h2>
      <div style="margin-top: var(--space-lg);"></div>
      <div class="testimonials-grid">
        {testimonials.map(t => (
          <div class={`testimonial-card ${t.featured ? 'featured' : ''}`}>
            <div class="star-rating">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="testimonial-quote">{t.quote}</p>
            <div class="testimonial-author">{t.author}</div>
            <div class="testimonial-source">via {t.source}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery — Real before/after work -->
  <section class="section-alt" id="gallery">
    <div class="container">
      <div class="section-header-flex">
        <div>
          <div class="section-label">Our Work</div>
          <h2>Before & After Portfolio</h2>
        </div>
        <a href="/services" class="btn btn-secondary btn-sm">View All Services &rarr;</a>
      </div>
      <div class="gallery-grid">
        {galleryItems.map(item => (
          <div class="gallery-item">
            <img src={item.src} alt={item.alt} width="600" height="600" loading="lazy" decoding="async" />
            {item.type === 'before-after' && <span class="gallery-label">Before & After</span>}
            {item.type === 'after' && <span class="gallery-label after">Completed</span>}
            <div class="gallery-caption">{item.caption}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section" id="areas">
    <div class="container">
      <div class="section-label">Service Coverage</div>
      <h2>Pool Service Areas in Ellis County & Southern Dallas County</h2>
      <p class="section-subtitle">Royal Blue Pool Service provides prompt, reliable pool maintenance and repair throughout the Midlothian area. Most service calls are scheduled within 48 hours.</p>
      <div class="service-areas-list">
        {serviceAreas.map(area => (
          <span class="area-tag">{area}, TX</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-alt" id="faq">
    <div class="container">
      <div class="section-label">Common Questions</div>
      <h2>Pool Service FAQ</h2>
      <div style="margin-top: var(--space-lg);"></div>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready for a Crystal-Clear Pool?</h2>
      <p>Get a free estimate from Midlothian's trusted pool service. Over 20 years of experience, licensed, insured, and ready to help.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary">Get Your Free Estimate</a>
        <a href={`tel:${phoneClean}`} class="btn btn-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call {phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
