---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const phone = '(214) 243-7107';
const phoneClean = phone.replace(/[^+\d]/g, '');

const faqs = [
  {
    question: "How often should I have my pool professionally serviced?",
    answer: "We recommend weekly pool maintenance for optimal water chemistry and cleanliness. Texas heat accelerates algae growth and chemical evaporation, making consistent weekly service essential. Our weekly plans include skimming, vacuuming, brushing, chemical testing and balancing, and equipment checks."
  },
  {
    question: "What areas do you serve around Midlothian?",
    answer: "Royal Blue Pool Service proudly serves Midlothian and the surrounding communities in Ellis County and southern Dallas County, including DeSoto, Cedar Hill, Duncanville, Red Oak, Ovilla, Waxahachie, Lancaster, Grand Prairie, Ferris, Ennis, Oak Cliff, Pecan Hill, and Oak Leaf."
  },
  {
    question: "Are you licensed and insured?",
    answer: "Yes. Royal Blue Pool Service is fully licensed by the Texas Department of Licensing and Regulation (TICL #1056) and fully insured. Owner Derrick Jackson brings over 20 years of professional pool service experience."
  },
  {
    question: "What pool equipment brands do you service?",
    answer: "We are a Certified Pentair Warranty Service Center and a Certified Polaris Warranty Dealer, which means we can perform warranty repairs on Pentair pumps, filters, heaters, and Polaris automatic cleaners. We also service equipment from all major manufacturers."
  },
  {
    question: "Do you offer free estimates?",
    answer: "Yes, we provide free repair and remodel estimates. We also offer a free 30-minute on-site pool education session for new pool owners in our service area, where we teach you about your equipment and basic water chemistry."
  },
  {
    question: "How do you handle a green pool?",
    answer: "Our green pool recovery service involves a multi-step process: assessing the cause of the algae bloom, performing a professional shock treatment, running filtration cycles, brushing pool surfaces, and rebalancing all chemical levels. Most green pools are restored to crystal-clear condition within 3-5 days depending on severity."
  },
  {
    question: "How much does weekly pool maintenance cost?",
    answer: "Weekly pool maintenance pricing varies based on pool size, equipment type, and any special requirements. We offer competitive rates for the Midlothian and Ellis County area. Contact us for a free, no-obligation estimate tailored to your pool."
  },
  {
    question: "Do you offer one-time pool cleanings?",
    answer: "Yes, we offer one-time pool cleanings for green pool recovery, seasonal openings and closings, and other situations where you need a single professional cleaning rather than ongoing service. Call us at (214) 243-7107 to schedule."
  },
  {
    question: "What is included in your weekly maintenance?",
    answer: "Our weekly maintenance service includes chemical testing and balancing, skimming the surface, vacuuming the pool floor, brushing walls and tile, emptying skimmer and pump baskets, and a full equipment inspection to catch potential issues early."
  },
  {
    question: "How long does a pool replaster take?",
    answer: "A typical pool replaster takes 1-2 weeks from start to finish, including surface preparation, plaster application, and proper cure time. The exact timeline depends on the pool size, the condition of the existing surface, and the finish selected. We use premium Stonescapes and Wet Edge finishes for long-lasting results."
  },
  {
    question: "Do you work on saltwater pools?",
    answer: "Yes, we service saltwater pools including salt cell cleaning, salt cell replacement, and maintaining proper salt and chemical levels. Our team is experienced with all major saltwater chlorination systems and can help troubleshoot any issues with your salt system."
  },
];

const title = 'Pool Service FAQ | Royal Blue Pool Service';
const description = 'Answers to common pool service questions in Midlothian, TX. Learn about weekly maintenance, pricing, green pool recovery, and more from Royal Blue Pool Service.';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'FAQ', href: '/faq' },
];
---
<BaseLayout
  title={title}
  description={description}
  canonicalUrl="https://royalbluepools.org/faq"
  jsonLd={[faqSchema]}
>

  <Breadcrumbs items={breadcrumbs} />

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section-label">Common Questions</div>
      <h1>Pool Service FAQ</h1>
      <p class="section-subtitle">Have questions about pool maintenance, repairs, or our services? Browse our frequently asked questions below, or call us at <a href={`tel:${phoneClean}`}>{phone}</a> for a quick answer.</p>
      <div style="margin-top: var(--space-lg);"></div>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Still Have Questions?</h2>
      <p>We're happy to help. Get a free estimate or call Derrick directly for expert pool advice.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary">Get Your Free Estimate</a>
        <a href={`tel:${phoneClean}`} class="btn btn-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call {phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
