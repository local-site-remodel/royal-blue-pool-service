---
const phone = '(214) 243-7107';
const phoneClean = phone.replace(/[^+\d]/g, '');

const services = [
  { name: 'Weekly Pool Maintenance', href: '/services/weekly-pool-maintenance' },
  { name: 'Pool Equipment Repair', href: '/services/pool-equipment-repair' },
  { name: 'Green Pool Recovery', href: '/services/green-pool-recovery' },
  { name: 'Pool Remodeling', href: '/services/pool-remodeling' },
  { name: 'Filter Cleaning', href: '/services/filter-cleaning' },
  { name: 'Pool Education', href: '/services/pool-education' },
];
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img src="/images/logo-water.svg" alt="Royal Blue Pool Service logo" width="42" height="42" loading="eager" />
      <div class="header-logo-text">
        <span class="header-logo-name">Royal Blue Pool Service</span>
        <span class="header-logo-sub">Midlothian, TX</span>
      </div>
    </a>

    <nav>
      <ul class="desktop-nav">
        <li><a href="/">Home</a></li>
        <li class="nav-dropdown">
          <a href="/services">Services</a>
          <div class="nav-dropdown-menu">
            {services.map(s => (
              <a href={s.href}>{s.name}</a>
            ))}
          </div>
        </li>
        <li><a href="/reviews">Reviews</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <a href={`tel:${phoneClean}`} class="header-cta">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {phone}
    </a>

    <button class="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-nav">
    <a href="/">Home</a>
    <a href="/services">Services</a>
    <div class="mobile-nav-services">
      {services.map(s => (
        <a href={s.href}>{s.name}</a>
      ))}
    </div>
    <a href="/reviews">Reviews</a>
    <a href="/faq">FAQ</a>
    <a href="/about">About</a>
    <a href="/blog">Blog</a>
    <a href="/contact">Contact</a>
    <div class="mobile-nav-phone">
      <a href={`tel:${phoneClean}`} class="header-cta">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {phone}
      </a>
    </div>
  </div>
</header>
