---
const phone = '(214) 243-7107';
const phoneClean = phone.replace(/[^+\d]/g, '');
const currentYear = new Date().getFullYear();

const serviceAreas = [
  'Midlothian', 'DeSoto', 'Cedar Hill', 'Duncanville', 'Oak Cliff',
  'Grand Prairie', 'Lancaster', 'Red Oak', 'Ovilla', 'Pecan Hill',
  'Oak Leaf', 'Waxahachie', 'Ferris', 'Ennis'
];

const services = [
  { name: 'Weekly Maintenance', href: '/services/weekly-pool-maintenance' },
  { name: 'Equipment Repair', href: '/services/pool-equipment-repair' },
  { name: 'Green Pool Recovery', href: '/services/green-pool-recovery' },
  { name: 'Pool Remodeling', href: '/services/pool-remodeling' },
  { name: 'Filter Cleaning', href: '/services/filter-cleaning' },
  { name: 'Pool Education', href: '/services/pool-education' },
];
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="footer-logo-text">Royal Blue Pool Service</span>
        </div>
        <p>Family-owned pool service company proudly serving Midlothian and the surrounding Ellis County and southern Dallas County communities. Licensed (TICL #1056), insured, and committed to keeping your pool crystal clear.</p>
        <div class="footer-rating">
          <span class="star-rating">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span>4.7 Stars on Google</span>
        </div>
      </div>

      <div>
        <h4 class="footer-heading">Pages</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/reviews">Reviews</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-links">
          {services.map(s => (
            <li><a href={s.href}>{s.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="footer-heading">Contact</h4>
        <div class="footer-contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <a href={`tel:${phoneClean}`}>{phone}</a>
        </div>
        <div class="footer-contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Midlothian, TX 76065</span>
        </div>
        <div class="footer-contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          <a href="https://www.facebook.com/royalbluepoolsllc/" target="_blank" rel="noopener noreferrer">Facebook</a>
        </div>
      </div>
    </div>

    <div class="footer-service-areas">
      <p>
        Proudly serving{' '}
        {serviceAreas.map((area, i) => (
          <>
            {area}{i < serviceAreas.length - 1 && <span>&bull;</span>}
          </>
        ))}
      </p>
    </div>

    <div class="footer-bottom">
      &copy; {currentYear} Royal Blue Pool Service LLC. All rights reserved. TICL #1056
    </div>
  </div>
</footer>
